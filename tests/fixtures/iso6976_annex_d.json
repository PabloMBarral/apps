{
  "_meta": {
    "source": "ISO 6976:2016 Annex D — Example calculations",
    "purpose": "Test fixtures for core/combustion/iso6976.py implementation",
    "notes": [
      "All compositions are normalized to sum=1.000000.",
      "Composition uncertainties u(x_i) are absolute (same units as x_i).",
      "Reference conditions follow the standard: T in celsius, P in kPa.",
      "Examples 1 and 2 use identity matrix for mole fraction correlations (no inter-component correlations).",
      "Example 3 includes both identity-matrix and normalization-matrix results.",
      "Tolerances suggested are conservative; implementation should match to the last reported decimal."
    ],
    "_precision_notes": [
      "Compression factor tolerances are loosened in some cases to account for the 4-decimal precision of summation factors in Table 2, which propagates to ~6-decimal precision in Z = 1 − s².",
      "Specifically: example_2.expected_intermediate.compression_factor uses tol_abs = 2.0e-6 (instead of 1.0e-6) because the water summation factor at 15.55 °C is tabulated as 0.2546 (4 decimals); a more precise implementation of Z is consistent with the input data precision."
    ]
  },

  "example_1": {
    "description": "D.2 — A simple mixture of five components",
    "reference_section": "ISO 6976:2016 D.2",
    "inputs": {
      "composition_mol_fraction": [
        {"name": "methane",        "x": 0.933212, "u_x": 0.000346},
        {"name": "ethane",         "x": 0.025656, "u_x": 0.000243},
        {"name": "propane",        "x": 0.015368, "u_x": 0.000148},
        {"name": "nitrogen",       "x": 0.010350, "u_x": 0.000195},
        {"name": "carbon dioxide", "x": 0.015414, "u_x": 0.000111}
      ],
      "combustion_reference": {"T_celsius": 15,    "P_kPa": 101.325},
      "metering_reference":   {"T_celsius": 15,    "P_kPa": 101.325},
      "correlation_matrix": "identity"
    },
    "expected_intermediate": {
      "molar_mass_kg_per_kmol":     {"value": 17.388430,    "tol_abs": 1.0e-5},
      "summation_factor":           {"value": 0.047305,     "tol_abs": 1.0e-5},
      "compression_factor":         {"value": 0.99776224,   "tol_abs": 1.0e-7},
      "molar_volume_m3_per_mol":    {"value": 0.023591917,  "tol_abs": 1.0e-8}
    },
    "expected_final": {
      "Hc_G_molar_kJ_per_mol": {"value": 906.179959, "u": 0.615609872, "U_k2": 1.2,   "tol_abs": 1.0e-5},
      "Hm_G_mass_MJ_per_kg":   {"value": 52.113961,  "u": 0.024301,    "U_k2": 0.049, "tol_abs": 1.0e-5},
      "Hv_G_volume_MJ_per_m3": {"value": 38.410611,  "u": 0.026267,    "U_k2": 0.053, "tol_abs": 1.0e-5}
    }
  },

  "example_2": {
    "description": "D.3 — A simple mixture containing water vapour. Note 15.55 °C ref instead of 15 °C.",
    "reference_section": "ISO 6976:2016 D.3",
    "inputs": {
      "composition_mol_fraction": [
        {"name": "methane",        "x": 0.931819, "u_x": 0.000350},
        {"name": "ethane",         "x": 0.025618, "u_x": 0.000243},
        {"name": "nitrogen",       "x": 0.010335, "u_x": 0.000195},
        {"name": "carbon dioxide", "x": 0.015391, "u_x": 0.000111},
        {"name": "water",          "x": 0.016837, "u_x": 0.000162}
      ],
      "combustion_reference": {"T_celsius": 15.55, "P_kPa": 101.325},
      "metering_reference":   {"T_celsius": 15.55, "P_kPa": 101.325},
      "correlation_matrix": "identity"
    },
    "expected_intermediate": {
      "molar_mass_kg_per_kmol":     {"value": 16.989170,    "tol_abs": 1.0e-5},
      "summation_factor":           {"value": 0.049306,     "tol_abs": 1.0e-5},
      "compression_factor":         {"value": 0.997570,     "tol_abs": 2.0e-6},
      "molar_volume_m3_per_mol":    {"value": 0.023632824,  "tol_abs": 1.0e-8}
    },
    "expected_final": {
      "Hc_G_molar_kJ_per_mol": {"value": 871.443916, "u": 0.522493911, "U_k2": 1.0,   "tol_abs": 1.0e-5},
      "Hm_G_mass_MJ_per_kg":   {"value": 51.294085,  "U_k2": 0.052,                    "tol_abs": 1.0e-5},
      "Hv_G_volume_MJ_per_m3": {"value": 36.874304,  "U_k2": 0.045,                    "tol_abs": 1.0e-5}
    },
    "validation_notes": [
      "j=42 (water vapor) in Tabla 3 has Hc = L0(water) from Annex A.5. So water in fuel contributes 44.408 kJ/mol at 15.55 °C, ie its latent heat."
    ]
  },

